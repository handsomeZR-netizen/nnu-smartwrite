# DeepSeek API key — 必填，否则 /api/evaluate 和 /api/chat 会返回 CONFIG_ERROR
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 本地开发地址，默认即可（Vercel 部署后改成 https://<your-project>.vercel.app）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MinerU OCR API token — 可选，缺失时 /api/ocr 走 lightweight Agent 回退
# 申请地址：https://mineru.net/apiManage
MINERU_API_TOKEN=
